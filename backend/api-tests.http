@baseUrl = http://localhost:5000/api
@token = {{login.response.body.data.accessToken}}

### ==========================================
### 1. HEALTH AND BASIC ROUTES
### ==========================================

### Basic Route
GET http://localhost:5000/

### Health Check
GET {{baseUrl}}/health

### ==========================================
### 2. AUTHENTICATION (authRoutes.ts)
### ==========================================

### Register a User
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Test User",
  "email": "testuser@example.com",
  "password": "Password123!"
}

### Login User
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "testuser@example.com",
  "password": "Password123!"
}

### Logout User
POST {{baseUrl}}/auth/logout
Content-Type: application/json

### Refresh Token
POST {{baseUrl}}/auth/refresh-token
Content-Type: application/json

{
  "token": "{{login.response.body.data.refreshToken}}"
}

### Forgot Password
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "testuser@example.com"
}

### Reset Password
# Note: Provide the 6-digit OTP received in the email
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "REPLACE_WITH_OTP_FROM_EMAIL",
  "newPassword": "NewPassword123!"
}

### Verify Email
# Note: You need to extract the verificationToken generated in the DB to use this
GET {{baseUrl}}/auth/verify-email/REPLACE_WITH_VERIFICATION_TOKEN_FROM_DB

### ==========================================
### 3. USERS (userRoutes.ts)
### ==========================================

### Get All Users
GET {{baseUrl}}/users
Authorization: Bearer {{token}}

### Register User (Alternative via User Route)
POST {{baseUrl}}/users
Content-Type: application/json

{
  "name": "Jane Doe",
  "email": "janedoe@example.com",
  "password": "Password123!"
}

### ==========================================
### 4. INSTITUTES (instituteRoutes.ts)
### ==========================================

